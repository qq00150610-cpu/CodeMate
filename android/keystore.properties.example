// keystore.properties.example - 签名配置模板
// =============================================================================
// 使用说明：
// 1. 复制此文件为 keystore.properties
// 2. 填入实际的签名配置信息
// 3. 不要将此文件提交到版本控制系统
// =============================================================================

# 密钥库路径（相对于 android 目录）
key.store=app/codemate.keystore

# 密钥别名
key.alias=codemate

# 密钥库密码
# 注意：建议使用环境变量替代明文密码
key.store.password=YOUR_KEYSTORE_PASSWORD

# 密钥密码
key.alias.password=YOUR_KEY_PASSWORD

# =============================================================================
# 使用环境变量的方式（推荐）
# =============================================================================
# 在 CI/CD 环境中，建议通过环境变量传递密码：
# 
# 1. GitHub Actions:
#    在 Settings > Secrets 中添加 KEYSTORE_PASSWORD
#    在 workflow 中使用: ${{ secrets.KEYSTORE_PASSWORD }}
#
# 2. 本地构建:
#    export KEYSTORE_PASSWORD=your_password
#    export KEY_ALIAS_PASSWORD=your_password
# =============================================================================

# =============================================================================
# Debug 签名配置（默认使用 Android Studio 自动生成的调试密钥）
# =============================================================================
debug.key.store=app/debug.keystore
debug.key.alias=androiddebugkey
debug.key.store.password=android
debug.key.alias.password=android

# =============================================================================
# 多渠道签名配置
# =============================================================================

# Google Play
google-play.key.store=app/google-play.keystore
google-play.key.alias=google-play

# 华为应用市场
huawei.key.store=app/huawei.keystore
huawei.key.alias=huawei

# 小米应用商店
xiaomi.key.store=app/xiaomi.keystore
xiaomi.key.alias=xiaomi
