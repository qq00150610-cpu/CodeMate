# =============================================================================
# CodeMate 后端环境变量配置
# =============================================================================
# 复制此文件为 .env 并填写实际值
# =============================================================================

# 阿里云百炼 API 配置
# 获取地址: https://dashscope.console.aliyun.com/
BAI_LIAN_API_KEY=sk-e511f943447849769e588927c03fcffe

# 百炼 API 地址（默认）
BAI_LIAN_API_URL=https://dashscope.aliyuncs.com/api/v1

# 服务配置
PORT=3000
NODE_ENV=development

# JWT 密钥（用于生成访问令牌）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 验证码配置
CAPTCHA_EXPIRE_SECONDS=300
CAPTCHA_WIDTH=120
CAPTCHA_HEIGHT=40

# 速率限制
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS 配置（允许的来源）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 日志级别
LOG_LEVEL=info

# 百炼模型配置
DEFAULT_MODEL=qwen-turbo
MAX_TOKENS=2000
TEMPERATURE=0.7
